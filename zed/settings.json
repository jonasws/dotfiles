{
  "ui_font_size": 18,
  "buffer_font_family": "JetBrainsMonoNL Nerd Font Mono",
  "buffer_font_size": 15,
  "auto_update": false,
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Catppuccin Mocha"
  },
  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "never",
    "use_smartcase_find": true
  },
  "outline_panel": {
    "dock": "right",
    "default_width": 300
  },
  "inlay_hints": {
    "enabled": true
  },
  "show_edit_predictions": true,
  "relative_line_numbers": true,
  "scrollbar": {
    "show": "always"
  },
  "tabs": {
    "file_icons": true,
    "git_status": true
  },
  "project_panel": {
    "dock": "left",
    "default_width": 300
  }
}
