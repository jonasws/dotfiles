; aws-vault-based AWS config (Option C1).
;
; Master IAM user creds live in macOS Keychain via aws-vault. Master
; profile (`capra-auth`) exposes an MFA'd STS session via credential_process
; so the SDK gets pre-authenticated temporary creds. Target profiles do
; single-hop AssumeRole on top of that session, so the role trust policy's
; `aws:MultiFactorAuthPresent=true` condition is satisfied without the SDK
; having to prompt for MFA at AssumeRole time.
;
; Role chaining (master-session -> target AssumeRole) still caps browser
; console / assume-role sessions at 1h. That ceiling is AWS-enforced.
;
; Activate with:
;   AWS_CONFIG_FILE=~/dotfiles/aws/.aws/config-vault
; or symlink in place of ~/.aws/config.
;
; One-time seeding of master IAM user creds (stored in macOS Keychain
; under the `aws-vault` keychain):
;   aws-vault add capra-auth
;   # paste AccessKeyId + SecretAccessKey from 1Password
;
; Per-profile use (AWS_PROFILE-native, no `aws-vault exec` prefix needed):
;   AWS_PROFILE=cnops-staging-developer aws s3 ls
;
; Optional env tunables (see aws-vault USAGE.md):
;   AWS_SESSION_TOKEN_TTL=1h   # master MFA session cache
;   AWS_ASSUME_ROLE_TTL=1h     # target AssumeRole cache

[profile capra-auth]
region=eu-west-1
output=json
mfa_serial=arn:aws:iam::259731000386:mfa/jstr
; MFA'd STS session credentials. Without --no-session, aws-vault calls
; GetSessionToken (MFA-gated) and caches the result in Keychain so only
; one MFA prompt is needed per duration_seconds (12h below).
; aws-vault will prompt interactively for the OTP code; supply it from
; your 1Password app (copy from the item or hit Cmd+Shift+X autofill).
duration_seconds=43200
credential_process=aws-vault export --format=json capra-auth

